@article{denningtonPhenotypicVariationPopulations2025,
  title = {Phenotypic Variation in Populations of the Mosquito Vector, {\emph{Aedes aegypti}}, and Implications for Predicting the Effects of Temperature and Climate Change on Dengue Transmission},
  author = {Dennington, Nina and Thomas, Matthew and McGraw, Elizabeth and Grossman, Marissa and Johnson, Leah and Teeple, Janet and Shocket, Marta},
  year = 2025,
  month = nov,
  pages = {2946196 bytes},
  publisher = {Dryad},
  doi = {10.5061/DRYAD.SXKSN03BM},
  urldate = {2026-03-30},
  abstract = {There is concern that increases in temperature due to climate change could  lead to shifts in the dynamics and distribution of mosquito vectors. Many  current models assume there are 'average' thermal performance  curves for a given vector species transmission. However, this  `one-size-fits-all' assumption ignores the potential for local adaptation  to create population-specific differences in thermal performance. In this  study, we explored thermal performance of five independent field  populations of Ae. aegypti from Mexico, together with a standard  laboratory strain. We reared these six populations at temperatures between  13{$^\circ$}C and 37{$^\circ$}C to generate thermal performance curves for a suite of  life-history traits. Composite models integrating these traits revealed  the effects of temperature on population growth rates and dengue virus  transmission potential. The results provide strong evidence for the  potential for local adaptation in Ae. aegypti populations, challenging  applicability of `one-size-fits-all' thermal performance models to assess  climate impact on mosquito-borne diseases.},
  copyright = {Creative Commons Zero v1.0 Universal},
  langid = {english},
  keywords = {adaptation,FOS: Biological sciences,Mosquitoes,population fitness,Vector-borne diseases}
}

