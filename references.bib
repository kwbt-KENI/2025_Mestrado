@article{linleydurak1989,
author = {Linley,J. R. and Duzak,D.},
title = {Egg cannibalism and carnivory among three species of Toxorhynchites.},
year = {1989},
volume = {5},
pages = {359–362},
language ={English},
item-type = {Journal article},
abstract = {In laboratory experiments, 3rd- and early 4th-instar larvae of T. amboinensis, T. splendens and T. brevipalpis, previously starved for 24 h, rapidly cannibalized eggs of their own species, or ate the eggs of other species present on the water surface in small containers. Larvae of T. amboinensis and T. splendens of either instar cannibalized eggs somewhat more rapidly than T. brevipalpis, probably because eggs of T. brevipalpis distributed themselves around the edge of the container and were less accessible. When offered heterospecific eggs, 4th-instar larvae of all 3 species ate them as efficiently as they cannibalized their own, except that eggs of T. brevipalpis were eaten very slowly. T. amboinensis larvae were offered conspecific hatched eggs, and these also were consumed.},
ISSN = {1943-6270 8756-971X} ,
issue = {3}
}

@article{jenkins1964,
author = {Jenkins,D. W.},
title = {Pathogens, Parasites and Predators of Medically Important Arthropods. Annotated List and Bibliography.},
year = {1964},
volume = {30},
pages = {150 pp.},
publisher = {World Health Organization},
address = {Geneva},
language ={Undetermined},
item-type = {Journal article},
abstract = {There is growing interest and research concerning the possibilities of using pathogens, parasites and predators (relatively specific to vectors of disease) for the control of vectors of human disease, partly to combat insecticide resistance but also to avoid insecticidal destruction of harmless, or beneficial, insects and acariñes or, indeed, other life which can result from the conventional widespread use of non-selective insecticides. Our knowledge of the whole subject is far from complete. Yet a surprising amount of information exists in a widely scattered literature and is often submerged as incidental observation in papers of wider topic. This publication attempts to bring all this together in a systematic manner and, while the author emphasizes that omissions must have occurred and invites notice of these, there is no doubt that a very comprehensive and most valuable compilation has been achieved.  The scope of these published records is clearly evident in 2 tables which show that there are about 600 known vector-pathogen (or parasite) associations and about 900 vector-predator associations. There is an encouraging degree of specificity in much of this. Protozoa comprise almost one-third of the parasitic species infecting vectors; parasitic wasps and other hymenoptera account for about a sixth of the total (but mainly affect flies, tsetse and the like), while between 53 and 90 associations are known for some other groups of parasites or pathogens. Protozoal microsporidians, fungi (e.g. Coelomomyces) and mermithid nematodes seem to have particular promise for mosquito control, and viral pathogens may prove to be a fruitful field of exploration as yet in its infancy. About a quarter of the predators are fish species (for mosquitoes), while 161 dipterous predators attack mosquitoes or blackfly at some stage. Macrochelid mites and certain beetles probably call for more research as effective housefly predators. This sort of viewpoint is brought out in the introduction which also succinctly comments on major attempts, a few successful but others not or less so, to control insect pests and vectors by introduced parasitism or predation at different times in the history of economic and medical entomology.  The text is planned in 15 sections, each concerned with one of the major groups of medically important insects or acariñes, viz. sandflies and midges, blackflies, mosquitoes, horseflies and deerflies, houseflies, stableflies, tsetse, lice, fleas, bedbugs, triatomid bugs, cockroaches, urticating lepidoptera, ticks and mites, and finally, the black widow spider. In each section are recorded the parasites (or pathogens) and predators affecting, in its developmental and adult stages, the type of vector under consideration.  For mosquitoes, the list occupies nearly half (39 pp.) of the text and ranges, for parasites, from a few reports of viral and rickettsia-like bodies through bacterial, spirochaetal, fungal, protozoal, rotiferan, parasitic worm and mite infections to predation of eggs, larvae and adults of mosquitoes by molluscs, other insects (and other arthropods), vertebrates and carnivorous plants. These parasites and predators are arranged by zoological classification and, under each parasitic or predatory species, is given at least a reference to its association with different mosquito species and, frequently, some indication of its efficacy as a control agent. The point is brought out in the work as a whole that we need to accumulate facts not only relevant to the possible use of these organisms in planned control projects but data bearing on their existing roles as factors controlling natural population densities of vector species.  Records for the other vector groups are as yet much fewer than for mosquitoes, being dealt with in a similar way for blackflies, in 9 pages, for houseflies in 6, horseflies in 5, and all other sections are covered by 4 or fewer pages each. There is a splendid list of over 2, 000 fully titled references.  Besides the wealth of condensed information listed in this compilation a remarkably good appreciation of how the main groups of the various parasites, pathogens and predators affect the vectors they attack is obtained from frequent introductory paragraphs on their biology dispersed throughout the systematic text, and some regard is given also, where relevant, to the adverse effects on vectors of organisms which they transmit in their capacity as vectors of disease to man. D. S. Bertram.},
ISSN = {1564-0604 0042-9686}
}

